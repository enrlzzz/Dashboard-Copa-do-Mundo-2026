	partition Dim_Calendario = calculated
		mode: import
		source = VAR _min = DATE(YEAR(MIN('Fato_Jogos'[Data])), 1, 1) VAR _max = DATE(YEAR(MAX('Fato_Jogos'[Data])), 12, 31) VAR _base = SELECTCOLUMNS(CALENDAR(_min, _max), "Data", [Date]) RETURN ADDCOLUMNS(_base, "Ano", YEAR([Data]), "Mês Núm", MONTH([Data]), "Mês", FORMAT([Data], "mmm", "pt-BR"), "Mês Ano", FORMAT([Data], "mmm/yyyy", "pt-BR"), "Trimestre", "T" & FORMAT([Data], "Q"), "Dia", DAY([Data]), "Dia Semana Núm", WEEKDAY([Data], 2), "Dia Semana", FORMAT([Data], "ddd", "pt-BR"), "Semana ISO", WEEKNUM([Data], 21))

