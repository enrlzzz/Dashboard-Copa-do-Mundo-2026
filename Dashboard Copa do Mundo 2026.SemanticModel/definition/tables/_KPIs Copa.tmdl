			    grid-auto-flow:column;
			    grid-template-rows:repeat(" & QtdeLinhas & ", minmax(52px, 1fr));
			    grid-template-columns:repeat(2, minmax(0, 1fr));
			    column-gap:88px;
			    row-gap:" & GapLinhas & ";
			    padding-top:32px;
			    padding-bottom:10px;
			    background:rgba(255,255,255,0) !important;
